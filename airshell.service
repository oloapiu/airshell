[Unit]
Description=AirShell sensor daemon
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/airshell/airshell/daemon.py
WorkingDirectory=/home/airshell/airshell
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
